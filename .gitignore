# ===================================================================
# Agentic Trader — .gitignore
# Sube SOLO código. Fuera: secretos, datos, dependencias, y toda la
# documentación explícita (markdown, docs, specs, roadmap).
# ===================================================================

# ---- Secretos / credenciales (NUNCA al repo) ----
.env
.env.*
*.env
secrets/
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
credentials*.json
service-account*.json

# ---- Bases de datos / datos ----
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
# Caché del modelo de embeddings (fastembed) — ~130 MB, nunca al repo
fastembed_cache/
**/fastembed_cache/
*.dump
*.bak
data/

# ---- Documentación explícita (nada de esto se publica) ----
*.md
*.mdx
*.markdown
*.rst
*.adoc
docs/
doc/
# Excepción: SOLO el README del proyecto (raíz). El resto de .md siguen fuera.
!/README.md

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
.dmypy.json
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/
dist/
build/
*.egg-info/
.eggs/
.ipynb_checkpoints/

# ---- Node / Next.js ----
node_modules/
.next/
out/
.vercel/
.turbo/
*.tsbuildinfo
next-env.d.ts
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.eslintcache

# ---- Logs / temporales ----
*.log
logs/
tmp/
temp/
*.tmp
*.pid
*.seed

# ---- Herramientas locales / editor / IDE ----
.claude/
.cursor/
.idea/
.vscode/
*.swp
*.swo
*~

# ---- Sistema operativo ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
